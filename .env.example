# 虾片 (ClawClip) 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务端口（默认 8080）
PORT=8080

# 额外扫描的「龙虾」数据根（逗号或分号分隔），用于非默认路径或 Docker 挂载
# 例：CLAWCLIP_LOBSTER_DIRS=/data/my-openclaw-home
# CLAWCLIP_LOBSTER_DIRS=

# 模板 / Skill 写入时优先使用的主目录（默认：第一个探测到的根，否则 ~/.openclaw）
# CLAWCLIP_PRIMARY_LOBSTER_HOME=

# 虾片状态文件目录：预算、排行榜、导入会话等（默认：主数据根下的 cost-monitor/）
# CLAWCLIP_STATE_DIR=

# OpenClaw 官方状态目录（与 Gateway 一致）。设置后虾片会扫描该路径下的 agents/会话；未单独指定 CLAWCLIP_PRIMARY 时，npx clawhub install 也会把技能装到这里。
# 注意：勿将 OPENCLAW_HOME 设为已以 .openclaw 结尾的路径，否则部分版本会嵌套出 .openclaw/.openclaw；优先用 OPENCLAW_STATE_DIR。
# OPENCLAW_STATE_DIR=
