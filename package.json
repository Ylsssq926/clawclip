{
  "name": "clawclip",
  "version": "2026.03.25.1",
  "description": "🍤 虾片 (ClawClip) — AI Agent 回放可视化 + 能力评测 + 成本优化",
  "workspaces": ["server", "web"],
  "bin": {
    "clawclip": "bin/clawclip.mjs"
  },
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "start": "node bin/clawclip.mjs",
    "check": "npm run check --workspace=@clawclip/server && npm run check --workspace=@clawclip/web"
  },
  "author": "掠蓝 (Luolan)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ylsssq926/clawclip.git"
  },
  "homepage": "https://clawclip.luelan.online",
  "keywords": [
    "ai-agent",
    "agent-visualization",
    "session-replay",
    "benchmark",
    "cost-tracking",
    "openclaw",
    "zeroclaw",
    "token-cost",
    "llm-analytics",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
